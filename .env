# Local development. Unset = auto-derive LAN IP from the Expo dev server.
# Pinned to localhost so the iOS simulator reaches the host backend reliably
# (the dev machine's LAN IP isn't reachable here — firewall/IPv6 bind).
# For a PHYSICAL device, set this to your computer's LAN IP instead.
EXPO_PUBLIC_API_URL=http://localhost:5000
